# Copy this file to .env and fill in your Appwrite credentials

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id-here
VITE_APPWRITE_BUCKET_ID=your-bucket-id-here

# Optional — override the owner email used by the gallery login form
# (defaults to owner@wedding.local). Password is set in Appwrite, not here.
# VITE_GALLERY_EMAIL=owner@wedding.local
